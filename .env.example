# Copy to .env.local for local dev. The in-cluster deployment gets
# these values through the kustomize overlay + sealed secrets.

SERVER_PORT=8081
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Must match admission-services and auth-services. Tokens are issued
# by auth-services (password login) and by admission-services
# (magic-link EOI verification) — sis-services only decodes.
JWT_SECRET=super-secret-key

# Comma-separated email allowlist for /admin/* endpoints. Same value
# as admission-services' ADMIN_EMAILS; mismatch = admin user can
# access admission admin but not SIS admin (confusing).
ADMIN_EMAILS=admin@school-test.local
